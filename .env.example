# Copy this file to .env.staging or .env.prod and fill in values.
# Never commit real .env files with secrets.

# Environment identifier
ENV=development

# Feature flags
FEATURE_NEW_CHECKOUT=false

# Server
PORT=5000

# Database
DATABASE_URL=sqlite:///db_dev.sqlite

# Add real secrets here (use GitHub Secrets in CI):
# SECRET_KEY=your-secret-key
